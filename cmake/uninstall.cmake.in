# unified_ml uninstall script         
# Generated by CMake. Run: cmake --build build --target uninstall

if(NOT EXISTS "@CMAKE_CURRENT_BINARY_DIR@/install_manifest.txt")
  message(FATAL_ERROR
    "Cannot find install manifest:\n"
    "  @CMAKE_CURRENT_BINARY_DIR@/install_manifest.txt\n"
    "Run cmake --install first.")
endif()

file(READ "@CMAKE_CURRENT_BINARY_DIR@/install_manifest.txt" manifest)
string(REGEX REPLACE "\n" ";" manifest "${manifest}")

foreach(file ${manifest})
  message(STATUS "Removing: ${file}")
  if(IS_SYMLINK "${file}" OR EXISTS "${file}")
    file(REMOVE "${file}")
    if(EXISTS "${file}")
    message(WARNING "  Could not remove: ${file}  (check permissions)")
    endif()
  else()
    message(STATUS "  Does not exist: ${file}")
  endif()
endforeach()

message(STATUS "unified_ml uninstalled.")
